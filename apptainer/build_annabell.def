Bootstrap: docker
From: ubuntu:22.04
Stage: build

%setup
    mkdir -p ${APPTAINER_ROOTFS}/app

%files
    # Copy only the build-relevant project files to avoid host-side broken symlinks.
    ./configure.ac /app/annabell/
    ./configure /app/annabell/
    ./annabell.spec.in /app/annabell/
    ./Makefile.am /app/annabell/
    ./Makefile.in /app/annabell/
    ./aclocal.m4 /app/annabell/
    ./build-aux /app/annabell/build-aux
    ./src /app/annabell/src

%post
    set -eux

    apt-get update && apt-get install -y --no-install-recommends \
        g++ cmake libpcre3-dev libgtest-dev make pkg-config xz-utils \
        libpcre3 libgomp1 sed adduser automake autoconf libtool

    # On Debian/Ubuntu, libgtest-dev often ships sources only. Build/install libs.
    cd /usr/src/googletest
    cmake -S . -B build -DCMAKE_BUILD_TYPE=Release
    cmake --build build -j"$(nproc)"
    cmake --install build
    ldconfig

    # Build and install Annabell from the copied workspace sources.
    cd /app/annabell
    mkdir -p m4
    autoreconf -fiv
    ./configure
    # Keep output deterministic so the first failing command is visible in logs.
    make V=1 -j1
    make install

    rm -rf /var/lib/apt/lists/*

%runscript
    exec /usr/local/bin/annabell "$@"

%labels
    Author Chris
    Description "Annabell built from workspace sources"

