Bootstrap: docker
From: ubuntu:latest
Stage: build

%arguments
    ANNABELL_VERSION=annabell

%setup
    # This runs on the host to prepare files if needed
    mkdir -p ${APPTAINER_ROOTFS}/app

%files
    # Source code must be accessible relative to this file
    ../annabell_source_code/{{ ANNABELL_VERSION }}.tar.xz /app/

%post
    apt-get update && apt-get install -y --no-install-recommends \
        g++ cmake libpcre3-dev libgtest-dev make pkg-config xz-utils libpcre3 libgomp1 sed adduser automake autoconf libtool

    # Build Annabell
    cd /app
    tar -xvJf {{ ANNABELL_VERSION }}.tar.xz
    cd {{ ANNABELL_VERSION }}

    # Regenerate build system files to match the container's automake version
    autoreconf -fiv

    ./configure && make && make install


%runscript
    exec /usr/local/bin/annabell "$@"

%labels
    Author YourName
    Version {{ ANNABELL_VERSION }}